# TaskFi dashboard — build-time environment variables.
#
# Set these in Cloudflare Pages: Settings > Environment variables > Production
# (and a separate Preview set if you want PR previews to hit a staging API).
# All VITE_* values are bundled into the public JS — none of them are secrets.

# Backend API base URL (the front calls this at runtime).
# Production (Base Sepolia rollout): https://api.taskfi.xyz
VITE_API_URL=https://api.taskfi.xyz

# EVM chain id for SIWE sign-in and on-chain reads.
# Base mainnet = 8453, Base Sepolia testnet = 84532.
VITE_CHAIN_ID=84532

# RPC endpoints for on-chain reads (balances, passport metadata, etc).
# Only the one matching VITE_CHAIN_ID is actually used at runtime; ship both
# in production so the value can be flipped without a redeploy.
#
# These URLs end up in the public JS bundle — anyone visiting the site can
# read them from DevTools. QuickNode endpoints are callable from anywhere by
# default, so without restrictions a leaked URL lets anyone drain your quota.
# Recommended (not required) hardening in the QuickNode dashboard:
#   - Endpoint Security > Referrer allowlist: https://app.taskfi.xyz
#     (+ preview domains, e.g. https://*.taski-app.pages.dev)
#   - Endpoint Security > Method allowlist: restrict to read-only RPC methods
#     (eth_call, eth_getBalance, eth_blockNumber, eth_chainId,
#      eth_estimateGas, eth_getLogs, eth_getTransactionReceipt).
VITE_RPC_URL_BASE_MAINNET=https://your-key.base-mainnet.quiknode.pro/xxxxxxxx/
VITE_RPC_URL_BASE_SEPOLIA=https://your-key.base-sepolia.quiknode.pro/xxxxxxxx/

# Contract addresses ($TASK, USDC, passport, …) are NOT configured here —
# they come from the backend at runtime via /api/public/config. Edit
# backend/.env on the server and restart taskfi-backend; no front rebuild
# is needed when an address changes.
